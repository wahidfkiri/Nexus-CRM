APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=/extensions/google-calendar/oauth/callback
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=/extensions/google-drive/oauth/callback
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_REDIRECT_URI=/extensions/google-sheets/oauth/callback
GOOGLE_DOCX_CLIENT_ID=
GOOGLE_DOCX_CLIENT_SECRET=
GOOGLE_DOCX_REDIRECT_URI=/extensions/google-docx/oauth/callback
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REDIRECT_URI=/extensions/google-gmail/oauth/callback
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_CLIENT_SECRET=
GOOGLE_MEET_REDIRECT_URI=/extensions/google-meet/oauth/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=/extensions/slack/oauth/callback
SLACK_API_BASE_URL=https://slack.com/api
SLACK_CHANNEL_TYPES=public_channel,private_channel,im,mpim
SLACK_PAGE_SIZE=100
SLACK_MESSAGE_PAGE_SIZE=50
SLACK_SYNC_DAYS_PAST=14
SLACK_TIMEOUT=20
SLACK_SOCKET_IO_ENABLED=true
SLACK_SOCKET_IO_URL=http://127.0.0.1:6002
SLACK_SOCKET_IO_PATH=/socket.io
SLACK_SOCKET_IO_NAMESPACE=/
SLACK_SOCKET_IO_EMIT_URL=http://127.0.0.1:6002/emit
SLACK_SOCKET_IO_SERVER_TOKEN=
CHATBOT_PAGE_SIZE=40
CHATBOT_MAX_TEXT_LENGTH=10000
CHATBOT_MAX_FILE_SIZE_KB=10240
CHATBOT_STORAGE_DISK=public
CHATBOT_STORAGE_PATH=chatbot/messages
CHATBOT_SOCKET_IO_ENABLED=true
CHATBOT_SOCKET_IO_URL=http://127.0.0.1:6003
CHATBOT_SOCKET_IO_PATH=/socket.io
CHATBOT_SOCKET_IO_NAMESPACE=/
CHATBOT_SOCKET_IO_EMIT_URL=http://127.0.0.1:6003/emit
CHATBOT_SOCKET_IO_SERVER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=/auth/google/callback
